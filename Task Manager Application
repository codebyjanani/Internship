        <div class="progress-bar-bg">
          <div class="progress-bar-fill" id="prog-bar" style="width:0%"></div>
        </div>
      </div>
      <!-- TOOLBAR -->
      <div class="content-header">
        <div class="content-title" id="view-title">All Tasks <span id="view-count"></span></div>
        <button class="add-btn" onclick="openModal()">＋ New Task</button>
      </div>
      <div class="toolbar">
        <div class="search-wrap">
          <span class="search-icon">🔍</span>
          <input type="text" id="search-input" placeholder="Search tasks…" oninput="renderTasks()" />
        </div>
        <select class="filter-select" id="sort-select" onchange="renderTasks()">
          <option value="newest">Newest first</option>
          <option value="oldest">Oldest first</option>
          <option value="priority">By priority</option>
          <option value="due">By due date</option>
        </select>
        <div class="view-toggle">
          <button class="view-btn active" id="vb-kanban" onclick="setView('kanban')">⊞ Board</button>
          <button class="view-btn" id="vb-list" onclick="setView('list')">☰ List</button>
