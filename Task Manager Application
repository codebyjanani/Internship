      <!-- TASK AREA -->
      <div id="task-area"></div>
    </main>
  </div>
</div>
<div class="modal-overlay" id="task-modal" onclick="modalOverlayClick(event)">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="modal-title">New Task</div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-field">
      <label>Task title *</label>
      <input type="text" id="t-title" placeholder="What needs to be done?" />
    </div>
    <div class="modal-field">
      <label>Description</label>
      <textarea id="t-desc" rows="3" placeholder="Add more details…"></textarea>
    </div>
    <div class="modal-row">
      <div class="modal-field">
        <label>Status</label>
        <select id="t-status">
          <option value="todo">To Do</option>
          <option value="in-progress">In Progress</option>
          <option value="done">Done</option>
        </select>
      </div>
      <div class="modal-field">
        <label>Priority</label>
        <select id="t-priority">
          <option value="low">🟢 Low</option>
          <option value="medium" selected>🟡 Medium</option>
          <option value="high">🔴 High</option>
        </select>
      </div>
    </div>
    <div class="modal-row">
      <div class="modal-field">
        <label>Due date</label>
        <input type="date" id="t-due" />
      </div>
      <div class="modal-field">
        <label>Category</label>
        <select id="t-category">
          <option value="general">📁 General</option>
          <option value="work">💼 Work</option>
          <option value="personal">🏠 Personal</option>
          <option value="study">📚 Study</option>
          <option value="health">💪 Health</option>
        </select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal()">Cancel</button>
      <button class="btn-save" onclick="saveTask()">Save Task</button>
    </div>
  </div>
</div>
<div class="modal-overlay" id="confirm-modal" onclick="confirmOverlayClick(event)">
  <div class="modal" style="max-width:360px">
    <div class="confirm-body">
      <div class="confirm-icon">🗑️</div>
      <div class="confirm-title">Delete this task?</div>
      <div class="confirm-sub">This action cannot be undone.</div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeConfirm()">Cancel</button>
      <button class="btn-danger" onclick="confirmDelete()">Delete</button>
    </div>
  </div>
</div>
<div id="toast-container">
</div>
<script>
'use strict';
let currentUser  = null;
let tasks        = [];
let editingId    = null;
let deletingId   = null;
let currentFilter = 'all';
let currentView   = 'kanban';
let nextId        = 1;
function saveToStorage() {
  const key = 'tf_tasks_' + currentUser.email;
  localStorage.setItem(key, JSON.stringify(tasks));
  localStorage.setItem('tf_nextid', nextId);
}
function loadFromStorage() {
  const key = 'tf_tasks_' + currentUser.email;
  const raw = localStorage.getItem(key);
  tasks = raw ? JSON.parse(raw) : [];
  nextId = parseInt(localStorage.getItem('tf_nextid') || '1');
}
function getUsers() {
  return JSON.parse(localStorage.getItem('tf_users') || '[]');
}
function saveUsers(users) {
  localStorage.setItem('tf_users', JSON.stringify(users));
}
function showPanel(p) {
  document.getElementById('login-panel').style.display    = p === 'login'    ? '' : 'none';
  document.getElementById('register-panel').style.display = p === 'register' ? '' : 'none';
}
function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pass  = document.getElementById('login-pass').value;
  clearAuthErrors('login');
  let ok = true;
  if (!isValidEmail(email))  { showErr('login-email-err'); document.getElementById('login-email').classList.add('err'); ok=false; }
  if (pass.length < 6)       { showErr('login-pass-err');  document.getElementById('login-pass').classList.add('err');  ok=false; }
  if (!ok) return;
  const users = getUsers();
  const user  = users.find(u => u.email === email && u.pass === btoa(pass));
  if (!user) {
    showAlert('login-alert', 'Invalid email or password.', 'err'); return;
  }
  loginSuccess(user);
}
function doRegister() {
  const name  = document.getElementById('reg-name').value.trim();
  const email = document.getElementById('reg-email').value.trim();
  const pass  = document.getElementById('reg-pass').value;
  clearAuthErrors('reg');
  let ok = true;
  if (!name)              { showErr('reg-name-err');  document.getElementById('reg-name').classList.add('err');  ok=false; }
  if (!isValidEmail(email)){ showErr('reg-email-err'); document.getElementById('reg-email').classList.add('err'); ok=false; }
  if (pass.length < 6)   { showErr('reg-pass-err');  document.getElementById('reg-pass').classList.add('err');  ok=false; }
  if (!ok) return;
  const users = getUsers();
  if (users.find(u => u.email === email)) {
    showAlert('reg-alert', 'An account with this email already exists.', 'err'); return;
  }
  const user = { name, email, pass: btoa(pass) };
  users.push(user);
  saveUsers(users);
  showAlert('reg-alert', 'Account created! Signing you in…', 'ok');
  setTimeout(() => loginSuccess(user), 800);
}
function demoLogin() {
  const user = { name: 'Demo User', email: 'demo@taskflow.app', pass: btoa('demo123') };
  const users = getUsers();
  if (!users.find(u => u.email === user.email)) { users.push(user); saveUsers(users); }
  if (!localStorage.getItem('tf_tasks_demo@taskflow.app')) seedDemoTasks();
  loginSuccess(user);
}
function loginSuccess(user) {
  currentUser = user;
  localStorage.setItem('tf_current', JSON.stringify(user));
  loadFromStorage();
  document.getElementById('auth-screen').style.display = 'none';
  document.getElementById('app-screen').classList.add('active');
  const initials = user.name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
  document.getElementById('top-avatar').textContent = initials;
  document.getElementById('top-name').textContent   = user.name;
  renderAll();
  toast('Welcome back, ' + user.name.split(' ')[0] + '! 👋', 'success');
}
function doLogout() {
  currentUser = null; tasks = [];
  localStorage.removeItem('tf_current');
  document.getElementById('app-screen').classList.remove('active');
  document.getElementById('auth-screen').style.display = '';
  document.getElementById('login-email').value = '';
  document.getElementById('login-pass').value  = '';
  showPanel('login');
}
(function() {
  const saved = localStorage.getItem('tf_current');
  if (saved) { try { loginSuccess(JSON.parse(saved)); } catch(e) {} }
})();
function seedDemoTasks() {
  const today = new Date();
  const fmt = d => d.toISOString().split('T')[0];
  const d = n => { const x=new Date(today); x.setDate(x.getDate()+n); return fmt(x); };
  const demo = [
    { id:1,title:'Design landing page',desc:'Create wireframes and hi-fi mockup for the new marketing site.',status:'done',priority:'high',due:d(-2),category:'work',createdAt:Date.now()-86400000*5 },
    { id:2,title:'Set up CI/CD pipeline',desc:'Configure GitHub Actions for automated testing and deployment.',status:'in-progress',priority:'high',due:d(1),category:'work',createdAt:Date.now()-86400000*3 },
    { id:3,title:'Write unit tests',desc:'Cover all API endpoints with Jest test suite. Aim for 90% coverage.',status:'in-progress',priority:'medium',due:d(3),category:'work',createdAt:Date.now()-86400000*2 },
    { id:4,title:'Morning run 5k',desc:'30 minutes easy pace around the park.',status:'todo',priority:'medium',due:d(1),category:'health',createdAt:Date.now()-86400000 },
    { id:5,title:'Read TypeScript handbook',desc:'Chapters 4–7 on generics and utility types.',status:'todo',priority:'low',due:d(5),category:'study',createdAt:Date.now()-3600000 },
    { id:6,title:'Grocery shopping',desc:'Milk, eggs, bread, vegetables for the week.',status:'todo',priority:'low',due:d(0),category:'personal',createdAt:Date.now()-1800000 },
    { id:7,title:'Fix login bug',desc:'Users are being logged out unexpectedly after 5 minutes of inactivity.',status:'in-progress',priority:'high',due:d(-1),category:'work',createdAt:Date.now()-86400000*4 },
    { id:8,title:'Team retrospective',desc:'Facilitate the sprint 12 retrospective with the full team.',status:'done',priority:'medium',due:d(-3),category:'work',createdAt:Date.now()-86400000*6 },
  ];
  localStorage.setItem('tf_tasks_demo@taskflow.app', JSON.stringify(demo));
  localStorage.setItem('tf_nextid', '9');
}
function openModal(id) {
  editingId = id || null;
  const t = id ? tasks.find(x=>x.id===id) : null;
  document.getElementById('modal-title').textContent = t ? 'Edit Task' : 'New Task';
  document.getElementById('t-title').value    = t ? t.title    : '';
  document.getElementById('t-desc').value     = t ? t.desc     : '';
  document.getElementById('t-status').value   = t ? t.status   : 'todo';
  document.getElementById('t-priority').value = t ? t.priority : 'medium';
  document.getElementById('t-due').value      = t ? t.due      : '';
  document.getElementById('t-category').value = t ? t.category : 'general';
  document.getElementById('task-modal').classList.add('open');
}
function closeModal() { document.getElementById('task-modal').classList.remove('open'); }
function modalOverlayClick(e) { if (e.target === document.getElementById('task-modal')) closeModal(); }
function saveTask() {
  const title = document.getElementById('t-title').value.trim();
  if (!title) { toast('Task title is required.', 'error'); document.getElementById('t-title').focus(); return; }
  if (editingId) {
    const idx = tasks.findIndex(x=>x.id===editingId);
    tasks[idx] = { ...tasks[idx], title, desc:document.getElementById('t-desc').value.trim(), status:document.getElementById('t-status').value, priority:document.getElementById('t-priority').value, due:document.getElementById('t-due').value, category:document.getElementById('t-category').value };
    toast('Task updated ✓', 'success');
  } else {
    tasks.unshift({ id:nextId++, title, desc:document.getElementById('t-desc').value.trim(), status:document.getElementById('t-status').value, priority:document.getElementById('t-priority').value, due:document.getElementById('t-due').value, category:document.getElementById('t-category').value, createdAt:Date.now() });
    toast('Task created ✓', 'success');
  }
  saveToStorage(); closeModal(); renderAll();
}
function deleteTask(id) { deletingId = id; document.getElementById('confirm-modal').classList.add('open'); }
function closeConfirm() { document.getElementById('confirm-modal').classList.remove('open'); deletingId = null; }
function confirmOverlayClick(e) { if (e.target === document.getElementById('confirm-modal')) closeConfirm(); }
function confirmDelete() {
  tasks = tasks.filter(t=>t.id!==deletingId);
  saveToStorage(); closeConfirm(); renderAll();
  toast('Task deleted.', 'info');
}
function toggleStatus(id) {
  const t = tasks.find(x=>x.id===id);
  if (!t) return;
  const cycle = { todo:'in-progress', 'in-progress':'done', done:'todo' };
  t.status = cycle[t.status];
  saveToStorage(); renderAll();
  toast(t.status === 'done' ? '🎉 Task completed!' : 'Status updated.', t.status==='done'?'success':'info');
}
function setFilter(f) {
  currentFilter = f;
  ['all','todo','progress','done','high','medium','low'].forEach(k => {
    document.getElementById('sb-'+k)?.classList.remove('active');
  });
  const map = {'all':'all','todo':'todo','in-progress':'progress','done':'done','high':'high','medium':'medium','low':'low'};
  document.getElementById('sb-'+(map[f]||f))?.classList.add('active');
  if (window.innerWidth <= 640) document.getElementById('sidebar').classList.remove('open');
  renderTasks();
}
function setView(v) {
  currentView = v;
  document.getElementById('vb-kanban').classList.toggle('active', v==='kanban');
  document.getElementById('vb-list').classList.toggle('active',   v==='list');
  renderTasks();
}
function getFilteredTasks() {
  const q = document.getElementById('search-input')?.value.toLowerCase() || '';
  let list = tasks.filter(t => {
    const matchQ = !q || t.title.toLowerCase().includes(q) || t.desc.toLowerCase().includes(q);
    let matchF = true;
    if (currentFilter === 'todo')        matchF = t.status === 'todo';
    else if (currentFilter === 'in-progress') matchF = t.status === 'in-progress';
    else if (currentFilter === 'done')   matchF = t.status === 'done';
    else if (currentFilter === 'high')   matchF = t.priority === 'high';
    else if (currentFilter === 'medium') matchF = t.priority === 'medium';
    else if (currentFilter === 'low')    matchF = t.priority === 'low';
    return matchQ && matchF;
  });
  const sort = document.getElementById('sort-select')?.value || 'newest';
  const pOrd = {high:0,medium:1,low:2};
  if (sort === 'oldest')   list.sort((a,b) => a.createdAt - b.createdAt);
  else if (sort === 'priority') list.sort((a,b) => pOrd[a.priority] - pOrd[b.priority]);
  else if (sort === 'due') list.sort((a,b) => (a.due||'9') < (b.due||'9') ? -1 : 1);
  else list.sort((a,b) => b.createdAt - a.createdAt);
  return list;
}
function renderAll() { updateStats(); updateSideCounts(); renderTasks(); }
function updateStats() {
  const total  = tasks.length;
  const done   = tasks.filter(t=>t.status==='done').length;
  const active = tasks.filter(t=>t.status==='in-progress').length;
  const today  = new Date().toISOString().split('T')[0];
  const over   = tasks.filter(t=>t.due && t.due < today && t.status !== 'done').length;
  document.getElementById('s-total').textContent  = total;
  document.getElementById('s-done').textContent   = done;
  document.getElementById('s-active').textContent = active;
  document.getElementById('s-over').textContent   = over;
  const pct = total ? Math.round(done/total*100) : 0;
  document.getElementById('prog-pct').textContent = pct + '%';
  document.getElementById('prog-bar').style.width = pct + '%';
}
function updateSideCounts() {
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('cnt-all').textContent      = tasks.length;
  document.getElementById('cnt-todo').textContent     = tasks.filter(t=>t.status==='todo').length;
  document.getElementById('cnt-progress').textContent = tasks.filter(t=>t.status==='in-progress').length;
  document.getElementById('cnt-done').textContent     = tasks.filter(t=>t.status==='done').length;
  document.getElementById('cnt-high').textContent     = tasks.filter(t=>t.priority==='high').length;
  document.getElementById('cnt-medium').textContent   = tasks.filter(t=>t.priority==='medium').length;
  document.getElementById('cnt-low').textContent      = tasks.filter(t=>t.priority==='low').length;
}
function renderTasks() {
  const list = getFilteredTasks();
  const titles = { all:'All Tasks', todo:'To Do', 'in-progress':'In Progress', done:'Completed', high:'High Priority', medium:'Medium Priority', low:'Low Priority' };
  document.getElementById('view-title').innerHTML = esc(titles[currentFilter]||'Tasks') + `<span>(${list.length})</span>`;
  const area = document.getElementById('task-area');
  if (!list.length) {
    area.innerHTML = `<div class="empty-state"><div class="empty-icon">📭</div><div class="empty-title">No tasks found</div><div class="empty-sub">Add a new task or adjust your filters.</div></div>`;
    return;
  }
  area.innerHTML = currentView === 'kanban' ? renderKanban(list) : renderList(list);
}
function renderKanban(list) {
  const cols = [
    { key:'todo',        label:'To Do',       dotClass:'dot-todo' },
    { key:'in-progress', label:'In Progress',  dotClass:'dot-prog' },
    { key:'done',        label:'Done',         dotClass:'dot-done' },
  ];
  return `<div class="kanban">${cols.map(col => {
    const cards = list.filter(t=>t.status===col.key);
    return `<div class="kanban-col">
      <div class="kanban-col-header">
        <div class="kanban-col-title"><div class="kanban-dot ${col.dotClass}"></div>${col.label}</div>
        <div class="kanban-col-count">${cards.length}</div>
      </div>
      <div class="kanban-cards">
        ${cards.length ? cards.map(taskCard).join('') : '<div style="color:var(--muted);font-size:0.8rem;text-align:center;padding:1rem">Empty</div>'}
      </div>
    </div>`;
  }).join('')}</div>`;
}
function taskCard(t) {
  const today = new Date().toISOString().split('T')[0];
  const overdue = t.due && t.due < today && t.status !== 'done';
  const catIcon = {general:'📁',work:'💼',personal:'🏠',study:'📚',health:'💪'}[t.category]||'📁';
  return `<div class="task-card" onclick="openModal(${t.id})">
    <div class="task-card-top">
      <div class="task-card-title">${esc(t.title)}</div>
      <div class="task-actions" onclick="event.stopPropagation()">
        <button class="icon-btn check" onclick="toggleStatus(${t.id})" title="Cycle status">⟳</button>
        <button class="icon-btn edit"  onclick="openModal(${t.id})"    title="Edit">✏️</button>
        <button class="icon-btn del"   onclick="deleteTask(${t.id})"   title="Delete">🗑️</button>
      </div>
    </div>
    ${t.desc ? `<div class="task-card-desc">${esc(t.desc)}</div>` : ''}
    <div class="task-card-footer">
      <span class="priority-badge p-${t.priority}">${t.priority}</span>
      <span style="font-size:0.75rem">${catIcon}</span>
      ${t.due ? `<span class="due-date${overdue?' overdue':''}">${overdue?'⚠️ ':''} ${fmtDate(t.due)}</span>` : ''}
    </div>
  </div>`;
}
function renderList(list) {
  return `<div class="task-list">${list.map(t => {
    const today = new Date().toISOString().split('T')[0];
    const overdue = t.due && t.due < today && t.status !== 'done';
    return `<div class="task-row" onclick="openModal(${t.id})">
      <div class="task-row-check ${t.status==='done'?'done':''}" onclick="event.stopPropagation();toggleStatus(${t.id})" title="Toggle status"></div>
      <div class="task-row-info">
        <div class="task-row-title ${t.status==='done'?'done-text':''}">${esc(t.title)}</div>
        ${t.desc ? `<div class="task-row-sub">${esc(t.desc.slice(0,80))}${t.desc.length>80?'…':''}</div>` : ''}
      </div>
      <div class="task-row-right" onclick="event.stopPropagation()">
        <span class="priority-badge p-${t.priority}">${t.priority}</span>
        ${t.due ? `<span class="due-date${overdue?' overdue':''}" style="font-size:0.75rem">${fmtDate(t.due)}</span>` : ''}
        <button class="icon-btn edit" onclick="openModal(${t.id})"  title="Edit">✏️</button>
        <button class="icon-btn del"  onclick="deleteTask(${t.id})" title="Delete">🗑️</button>
      </div>
    </div>`;
  }).join('')}</div>`;
}
function toggleSidebar() { document.getElementById('sidebar').classList.toggle('open'); }
function closeSidebarOnClick(e) {
  const sb = document.getElementById('sidebar');
  if (sb.classList.contains('open') && !sb.contains(e.target)) sb.classList.remove('open');
}
function toast(msg, type='info') {
  const el = document.createElement('div');
  el.className = 'toast ' + type;
  el.innerHTML = (type==='success'?'✅':type==='error'?'❌':'ℹ️') + ' ' + msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 3000);
}
function isValidEmail(e) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e); }
function esc(s) { return String(s||'').replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]); }
function fmtDate(d) { if (!d) return ''; const [y,m,day]=d.split('-'); return `${day}/${m}/${y.slice(2)}`; }
function showErr(id)  { document.getElementById(id).classList.add('show'); }
function showAlert(id,msg,type) { const el=document.getElementById(id); el.textContent=msg; el.className='auth-alert '+type; }
function clearAuthErrors(prefix) {
  ['email','pass','name'].forEach(f => {
    const i = document.getElementById(prefix+'-'+f); if(i) { i.classList.remove('err'); }
    const e = document.getElementById(prefix+'-'+f+'-err'); if(e) e.classList.remove('show');
  });
  const a = document.getElementById(prefix+'-alert'); if(a) { a.className='auth-alert'; a.textContent=''; }
}
document.getElementById('login-pass').addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });
document.getElementById('reg-pass').addEventListener('keydown',   e => { if(e.key==='Enter') doRegister(); });
</script>
