<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TaskFlow — Task Management App</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:        #0F1117;
      --bg2:       #1A1D27;
      --bg3:       #222535;
      --border:    rgba(255,255,255,0.08);
      --indigo:    #6366F1;
      --indigo-dk: #4F46E5;
      --green:     #22C55E;
      --amber:     #F59E0B;
      --red:       #EF4444;
      --text:      #F1F5F9;
      --muted:     #94A3B8;
      --radius:    10px;
      --shadow:    0 4px 24px rgba(0,0,0,0.4);
      --t:         0.2s ease;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    a { color: inherit; text-decoration: none; }
    button { cursor: pointer; border: none; font: inherit; }
    input, textarea, select { font: inherit; }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 6px; } ::-webkit-scrollbar-track { background: var(--bg2); } ::-webkit-scrollbar-thumb { background: var(--bg3); border-radius: 99px; }

    /* ══════════════════════════════════════════
       AUTH SCREENS
    ══════════════════════════════════════════ */
    #auth-screen {
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(99,102,241,0.15), transparent 70%);
      padding: 1rem;
    }
    .auth-card {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: 20px; padding: 2.5rem; width: 100%; max-width: 420px;
      box-shadow: var(--shadow);
    }
    .auth-logo { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 2rem; }
    .auth-logo-icon { width: 36px; height: 36px; background: var(--indigo); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
    .auth-logo-name { font-size: 1.3rem; font-weight: 700; }
    .auth-logo-name span { color: var(--indigo); }
    .auth-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.4rem; }
    .auth-sub { color: var(--muted); font-size: 0.9rem; margin-bottom: 2rem; }
    .field { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.1rem; }
    .field label { font-size: 0.82rem; font-weight: 500; color: var(--text); }
    .field input {
      padding: 0.7rem 1rem; background: var(--bg3); border: 1px solid var(--border);
      border-radius: var(--radius); color: var(--text); font-size: 0.9rem;
      transition: border-color var(--t), box-shadow var(--t); outline: none;
    }
    .field input:focus { border-color: var(--indigo); box-shadow: 0 0 0 3px rgba(99,102,241,0.2); }
    .field input.err { border-color: var(--red); }
    .field-err { font-size: 0.78rem; color: var(--red); margin-top: 0.2rem; display: none; }
    .field-err.show { display: block; }
    .btn-full {
      width: 100%; padding: 0.78rem; background: var(--indigo); color: #fff;
      border-radius: var(--radius); font-weight: 600; font-size: 0.95rem;
      transition: opacity var(--t), transform var(--t);
      box-shadow: 0 4px 16px rgba(99,102,241,0.35);
    }
    .btn-full:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-full:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .auth-switch { text-align: center; margin-top: 1.5rem; font-size: 0.875rem; color: var(--muted); }
    .auth-switch a { color: var(--indigo); font-weight: 600; cursor: pointer; }
    .auth-switch a:hover { text-decoration: underline; }
    .auth-alert { padding: 0.7rem 1rem; border-radius: var(--radius); font-size: 0.85rem; margin-bottom: 1rem; display: none; }
    .auth-alert.err  { background: rgba(239,68,68,0.12);  border: 1px solid rgba(239,68,68,0.3);  color: #FCA5A5; display: block; }
    .auth-alert.ok   { background: rgba(34,197,94,0.12);  border: 1px solid rgba(34,197,94,0.3);  color: #86EFAC; display: block; }
    .divider { display: flex; align-items: center; gap: 0.75rem; margin: 1.25rem 0; }
    .divider hr { flex: 1; border: none; border-top: 1px solid var(--border); }
    .divider span { font-size: 0.78rem; color: var(--muted); }
    .demo-btn {
      width: 100%; padding: 0.7rem; background: var(--bg3); border: 1px solid var(--border);
      color: var(--muted); border-radius: var(--radius); font-size: 0.875rem;
      transition: border-color var(--t), color var(--t);
    }
    .demo-btn:hover { border-color: var(--indigo); color: var(--text); }

    /* ══════════════════════════════════════════
       APP LAYOUT
    ══════════════════════════════════════════ */
    #app-screen { display: none; min-height: 100vh; flex-direction: column; }
    #app-screen.active { display: flex; }

    /* TOPBAR */
    .topbar {
      position: sticky; top: 0; z-index: 50;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 1.5rem; height: 60px;
      background: rgba(15,17,23,0.85); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .topbar-left { display: flex; align-items: center; gap: 0.75rem; }
    .topbar-logo { font-size: 1.1rem; font-weight: 700; }
    .topbar-logo span { color: var(--indigo); }
    .topbar-right { display: flex; align-items: center; gap: 0.75rem; }
    .avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: linear-gradient(135deg, var(--indigo), #a78bfa);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem; font-weight: 700; color: #fff;
    }
    .user-name { font-size: 0.875rem; font-weight: 500; }
    .logout-btn {
      padding: 0.4rem 0.85rem; border-radius: 8px;
      background: var(--bg3); border: 1px solid var(--border);
      font-size: 0.8rem; color: var(--muted);
      transition: color var(--t), border-color var(--t);
    }
    .logout-btn:hover { color: var(--red); border-color: var(--red); }
    .hamburger-btn { display: none; flex-direction: column; gap: 4px; padding: 6px; }
    .hamburger-btn span { display: block; width: 20px; height: 2px; background: var(--muted); border-radius: 2px; }

    /* MAIN */
    .app-body { display: flex; flex: 1; overflow: hidden; height: calc(100vh - 60px); }

    /* SIDEBAR */
    .sidebar {
      width: 220px; flex-shrink: 0; padding: 1.25rem 0.75rem;
      background: var(--bg2); border-right: 1px solid var(--border);
      display: flex; flex-direction: column; gap: 0.25rem; overflow-y: auto;
    }
    .sidebar-label { font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); padding: 0.5rem 0.75rem; margin-top: 0.5rem; }
    .sidebar-item {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.55rem 0.75rem; border-radius: 8px;
      font-size: 0.875rem; color: var(--muted); cursor: pointer;
      transition: background var(--t), color var(--t);
      border: none; background: none; width: 100%; text-align: left;
    }
    .sidebar-item:hover { background: var(--bg3); color: var(--text); }
    .sidebar-item.active { background: rgba(99,102,241,0.15); color: var(--indigo); font-weight: 600; }
    .sidebar-item .si-icon { font-size: 1rem; width: 20px; text-align: center; }
    .sidebar-count { margin-left: auto; background: var(--bg3); border-radius: 99px; font-size: 0.7rem; padding: 0.1rem 0.5rem; color: var(--muted); }
    .sidebar-item.active .sidebar-count { background: rgba(99,102,241,0.2); color: var(--indigo); }

    /* CONTENT */
    .content { flex: 1; overflow-y: auto; padding: 1.75rem; }
    .content-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem; }
    .content-title { font-size: 1.35rem; font-weight: 700; }
    .content-title span { color: var(--muted); font-weight: 400; font-size: 1rem; margin-left: 0.5rem; }

    /* STATS ROW */
    .stats-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 1rem; margin-bottom: 1.75rem; }
    .stat-card {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 1.1rem 1.25rem;
    }
    .stat-label-sm { font-size: 0.78rem; color: var(--muted); margin-bottom: 0.35rem; }
    .stat-value { font-size: 1.8rem; font-weight: 700; line-height: 1; }
    .stat-sub { font-size: 0.75rem; color: var(--muted); margin-top: 0.3rem; }
    .stat-card.s-total  .stat-value { color: var(--text); }
    .stat-card.s-done   .stat-value { color: var(--green); }
    .stat-card.s-active .stat-value { color: var(--indigo); }
    .stat-card.s-over   .stat-value { color: var(--red); }

    /* TOOLBAR */
    .toolbar { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .search-wrap { position: relative; flex: 1; min-width: 180px; }
    .search-wrap input {
      width: 100%; padding: 0.6rem 1rem 0.6rem 2.4rem;
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: var(--radius); color: var(--text); font-size: 0.875rem; outline: none;
      transition: border-color var(--t);
    }
    .search-wrap input:focus { border-color: var(--indigo); }
    .search-icon { position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 0.9rem; pointer-events: none; }
    .filter-select {
      padding: 0.6rem 0.9rem; background: var(--bg2); border: 1px solid var(--border);
      border-radius: var(--radius); color: var(--text); font-size: 0.875rem; outline: none; cursor: pointer;
    }
    .filter-select option { background: var(--bg2); }
    .add-btn {
      display: flex; align-items: center; gap: 0.4rem;
      padding: 0.6rem 1.1rem; background: var(--indigo); color: #fff;
      border-radius: var(--radius); font-size: 0.875rem; font-weight: 600;
      transition: opacity var(--t), transform var(--t);
      box-shadow: 0 2px 12px rgba(99,102,241,0.3);
    }
    .add-btn:hover { opacity: 0.88; transform: translateY(-1px); }

    /* VIEW TOGGLE */
    .view-toggle { display: flex; gap: 0.25rem; background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 0.2rem; }
    .view-btn { padding: 0.3rem 0.6rem; border-radius: 6px; font-size: 0.85rem; color: var(--muted); transition: background var(--t), color var(--t); }
    .view-btn.active { background: var(--bg3); color: var(--text); }

    /* KANBAN */
    .kanban { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; }
    .kanban-col { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    .kanban-col-header { padding: 0.9rem 1rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .kanban-col-title { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; display: flex; align-items: center; gap: 0.5rem; }
    .kanban-dot { width: 8px; height: 8px; border-radius: 50%; }
    .dot-todo   { background: var(--muted); }
    .dot-prog   { background: var(--indigo); }
    .dot-done   { background: var(--green); }
    .kanban-col-count { font-size: 0.75rem; color: var(--muted); background: var(--bg3); border-radius: 99px; padding: 0.1rem 0.5rem; }
    .kanban-cards { padding: 0.75rem; display: flex; flex-direction: column; gap: 0.6rem; min-height: 80px; }

    /* TASK CARD */
    .task-card {
      background: var(--bg3); border: 1px solid var(--border);
      border-radius: 8px; padding: 0.9rem 1rem;
      transition: border-color var(--t), transform var(--t), box-shadow var(--t);
      cursor: pointer;
    }
    .task-card:hover { border-color: rgba(99,102,241,0.4); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.3); }
    .task-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.5rem; }
    .task-card-title { font-size: 0.875rem; font-weight: 600; line-height: 1.4; }
    .task-card-desc { font-size: 0.78rem; color: var(--muted); line-height: 1.5; margin-bottom: 0.75rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .task-card-footer { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.4rem; }
    .priority-badge { font-size: 0.68rem; font-weight: 600; padding: 0.2rem 0.55rem; border-radius: 99px; text-transform: uppercase; letter-spacing: 0.05em; }
    .p-low    { background: rgba(34,197,94,0.15);  color: #86EFAC; }
    .p-medium { background: rgba(245,158,11,0.15); color: #FCD34D; }
    .p-high   { background: rgba(239,68,68,0.15);  color: #FCA5A5; }
    .due-date { font-size: 0.72rem; color: var(--muted); }
    .due-date.overdue { color: var(--red); }
    .task-actions { display: flex; gap: 0.25rem; }
    .icon-btn { width: 26px; height: 26px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; color: var(--muted); transition: background var(--t), color var(--t); }
    .icon-btn:hover.edit  { background: rgba(99,102,241,0.15); color: var(--indigo); }
    .icon-btn:hover.del   { background: rgba(239,68,68,0.15);  color: var(--red); }
    .icon-btn:hover.check { background: rgba(34,197,94,0.15);  color: var(--green); }

    /* LIST VIEW */
    .task-list { display: flex; flex-direction: column; gap: 0.6rem; }
    .task-row {
      background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 0.9rem 1.1rem; display: flex; align-items: center; gap: 1rem;
      transition: border-color var(--t); cursor: pointer;
    }
    .task-row:hover { border-color: rgba(99,102,241,0.3); }
    .task-row-check { width: 18px; height: 18px; border-radius: 50%; border: 2px solid var(--border); flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: background var(--t), border-color var(--t); }
    .task-row-check.done { background: var(--green); border-color: var(--green); }
    .task-row-check.done::after { content: '✓'; font-size: 0.7rem; color: #fff; }
    .task-row-info { flex: 1; min-width: 0; }
    .task-row-title { font-size: 0.875rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .task-row-title.done-text { text-decoration: line-through; color: var(--muted); }
    .task-row-sub { font-size: 0.75rem; color: var(--muted); margin-top: 0.15rem; }
    .task-row-right { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }

    /* EMPTY STATE */
    .empty-state { text-align: center; padding: 4rem 2rem; color: var(--muted); }
    .empty-icon { font-size: 3rem; margin-bottom: 1rem; opacity: 0.5; }
    .empty-title { font-size: 1rem; font-weight: 600; color: var(--text); margin-bottom: 0.5rem; }
    .empty-sub { font-size: 0.875rem; }

    /* PROGRESS BAR */
    .progress-wrap { margin-bottom: 1.75rem; background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem 1.25rem; }
    .progress-label { display: flex; justify-content: space-between; font-size: 0.8rem; color: var(--muted); margin-bottom: 0.5rem; }
    .progress-bar-bg { height: 8px; background: var(--bg3); border-radius: 99px; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: linear-gradient(90deg, var(--indigo), #a78bfa); border-radius: 99px; transition: width 0.5s ease; }

    /* ══════════════════════════════════════════
       MODAL
    ══════════════════════════════════════════ */
    .modal-overlay {
      position: fixed; inset: 0; z-index: 200;
      background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
      display: flex; align-items: center; justify-content: center;
      padding: 1rem; opacity: 0; pointer-events: none;
      transition: opacity var(--t);
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }
    .modal {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: 16px; padding: 2rem; width: 100%; max-width: 480px;
      box-shadow: 0 24px 48px rgba(0,0,0,0.6);
      transform: translateY(16px); transition: transform var(--t);
    }
    .modal-overlay.open .modal { transform: translateY(0); }
    .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
    .modal-title { font-size: 1.1rem; font-weight: 700; }
    .modal-close { width: 30px; height: 30px; border-radius: 8px; background: var(--bg3); color: var(--muted); font-size: 1rem; display: flex; align-items: center; justify-content: center; transition: background var(--t), color var(--t); }
    .modal-close:hover { background: rgba(239,68,68,0.15); color: var(--red); }
    .modal-field { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
    .modal-field label { font-size: 0.82rem; font-weight: 500; }
    .modal-field input, .modal-field textarea, .modal-field select {
      padding: 0.7rem 1rem; background: var(--bg3); border: 1px solid var(--border);
      border-radius: var(--radius); color: var(--text); font-size: 0.875rem;
      outline: none; transition: border-color var(--t), box-shadow var(--t);
      resize: vertical;
    }
    .modal-field input:focus, .modal-field textarea:focus, .modal-field select:focus { border-color: var(--indigo); box-shadow: 0 0 0 3px rgba(99,102,241,0.2); }
    .modal-field select option { background: var(--bg2); }
    .modal-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .modal-footer { display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 1.5rem; }
    .btn-cancel { padding: 0.65rem 1.25rem; background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius); color: var(--muted); font-size: 0.875rem; font-weight: 500; transition: color var(--t), border-color var(--t); }
    .btn-cancel:hover { color: var(--text); border-color: rgba(255,255,255,0.15); }
    .btn-save { padding: 0.65rem 1.5rem; background: var(--indigo); color: #fff; border-radius: var(--radius); font-size: 0.875rem; font-weight: 600; transition: opacity var(--t); box-shadow: 0 2px 12px rgba(99,102,241,0.3); }
    .btn-save:hover { opacity: 0.88; }

    /* CONFIRM MODAL */
    .confirm-body { text-align: center; padding: 1rem 0; }
    .confirm-icon { font-size: 2.5rem; margin-bottom: 1rem; }
    .confirm-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
    .confirm-sub { font-size: 0.875rem; color: var(--muted); }
    .btn-danger { padding: 0.65rem 1.5rem; background: var(--red); color: #fff; border-radius: var(--radius); font-size: 0.875rem; font-weight: 600; transition: opacity var(--t); }
    .btn-danger:hover { opacity: 0.88; }

    /* TOAST */
    #toast-container { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 999; display: flex; flex-direction: column; gap: 0.5rem; }
    .toast {
      padding: 0.7rem 1.1rem; border-radius: var(--radius); font-size: 0.85rem; font-weight: 500;
      box-shadow: 0 4px 16px rgba(0,0,0,0.4); display: flex; align-items: center; gap: 0.5rem;
      animation: slideIn 0.3s ease; min-width: 220px;
    }
    .toast.success { background: rgba(34,197,94,0.9);  color: #fff; }
    .toast.error   { background: rgba(239,68,68,0.9);  color: #fff; }
    .toast.info    { background: rgba(99,102,241,0.9); color: #fff; }
    @keyframes slideIn { from { opacity:0; transform:translateX(20px); } to { opacity:1; transform:translateX(0); } }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .stats-row { grid-template-columns: repeat(2,1fr); }
      .kanban { grid-template-columns: 1fr; }
    }
    @media (max-width: 640px) {
      .sidebar { display: none; position: fixed; inset: 60px 0 0 0; z-index: 40; width: 100%; border-right: none; }
      .sidebar.open { display: flex; }
      .hamburger-btn { display: flex; }
      .stats-row { grid-template-columns: 1fr 1fr; }
      .content { padding: 1rem; }
      .modal-row { grid-template-columns: 1fr; }
      .topbar { padding: 0 1rem; }
      .user-name { display: none; }
    }
    @media (max-width: 400px) {
      .stats-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div id="auth-screen">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-icon">✅</div>
      <div class="auth-logo-name">Task<span>Flow</span></div>
    </div>
    <!-- LOGIN -->
    <div id="login-panel">
      <h2 class="auth-title">Welcome back</h2>
      <p class="auth-sub">Sign in to your workspace</p>
      <div id="login-alert" class="auth-alert"></div>
      <div class="field">
        <label>Email address</label>
        <input type="email" id="login-email" placeholder="you@example.com" />
        <span class="field-err" id="login-email-err">Please enter a valid email.</span>
      </div>
      <div class="field">
        <label>Password</label>
        <input type="password" id="login-pass" placeholder="••••••••" />
        <span class="field-err" id="login-pass-err">Password must be at least 6 characters.</span>
      </div>
      <button class="btn-full" id="login-btn" onclick="doLogin()">Sign in</button>
      <div class="divider"><hr /><span>or</span><hr /></div>
      <button class="demo-btn" onclick="demoLogin()">🚀 Continue with demo account</button>
      <p class="auth-switch">Don't have an account? <a onclick="showPanel('register')">Create one</a></p>
    </div>
    <!-- REGISTER -->
    <div id="register-panel" style="display:none">
      <h2 class="auth-title">Create account</h2>
      <p class="auth-sub">Start managing your tasks today</p>
      <div id="reg-alert" class="auth-alert"></div>
      <div class="field">
        <label>Full name</label>
        <input type="text" id="reg-name" placeholder="Jane Smith" />
        <span class="field-err" id="reg-name-err">Name is required.</span>
      </div>
      <div class="field">
        <label>Email address</label>
        <input type="email" id="reg-email" placeholder="you@example.com" />
        <span class="field-err" id="reg-email-err">Please enter a valid email.</span>
      </div>
      <div class="field">
        <label>Password</label>
        <input type="password" id="reg-pass" placeholder="At least 6 characters" />
        <span class="field-err" id="reg-pass-err">Password must be at least 6 characters.</span>
      </div>
      <button class="btn-full" id="reg-btn" onclick="doRegister()">Create account</button>
      <p class="auth-switch">Already have an account? <a onclick="showPanel('login')">Sign in</a></p>
    </div>
  </div>
</div>
<div id="app-screen">
  <!-- TOPBAR -->
  <header class="topbar">
    <div class="topbar-left">
      <button class="hamburger-btn" onclick="toggleSidebar()">
        <span></span><span></span><span></span>
      </button>
      <div class="topbar-logo">Task<span>Flow</span></div>
    </div>
    <div class="topbar-right">
      <div class="avatar" id="top-avatar">JD</div>
      <span class="user-name" id="top-name">Jane Doe</span>
