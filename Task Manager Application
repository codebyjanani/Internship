  <div class="app-body">
    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
      <span class="sidebar-label">Views</span>
      <button class="sidebar-item active" id="sb-all" onclick="setFilter('all')">
        <span class="si-icon">📋</span> All Tasks
        <span class="sidebar-count" id="cnt-all">0</span>
      </button>
      <button class="sidebar-item" id="sb-todo" onclick="setFilter('todo')">
        <span class="si-icon">⭕</span> To Do
        <span class="sidebar-count" id="cnt-todo">0</span>
      </button>
      <button class="sidebar-item" id="sb-progress" onclick="setFilter('in-progress')">
        <span class="si-icon">🔵</span> In Progress
        <span class="sidebar-count" id="cnt-progress">0</span>
      </button>
      <button class="sidebar-item" id="sb-done" onclick="setFilter('done')">
        <span class="si-icon">✅</span> Completed
        <span class="sidebar-count" id="cnt-done">0</span>
      </button>
      <span class="sidebar-label">Priority</span>
      <button class="sidebar-item" id="sb-high" onclick="setFilter('high')">
        <span class="si-icon">🔴</span> High Priority
        <span class="sidebar-count" id="cnt-high">0</span>
      </button>
      <button class="sidebar-item" id="sb-medium" onclick="setFilter('medium')">
        <span class="si-icon">🟡</span> Medium
        <span class="sidebar-count" id="cnt-medium">0</span>
      </button>
      <button class="sidebar-item" id="sb-low" onclick="setFilter('low')">
        <span class="si-icon">🟢</span> Low Priority
        <span class="sidebar-count" id="cnt-low">0</span>
      </button>
    </aside>
    <!-- MAIN CONTENT -->
    <main class="content" onclick="closeSidebarOnClick(event)">
      <!-- STATS -->
      <div class="stats-row">
        <div class="stat-card s-total">
          <div class="stat-label-sm">Total Tasks</div>
          <div class="stat-value" id="s-total">0</div>
          <div class="stat-sub">All time</div>
        </div>
        <div class="stat-card s-active">
          <div class="stat-label-sm">In Progress</div>
          <div class="stat-value" id="s-active">0</div>
          <div class="stat-sub">Active now</div>
        </div>
        <div class="stat-card s-done">
          <div class="stat-label-sm">Completed</div>
          <div class="stat-value" id="s-done">0</div>
          <div class="stat-sub">Well done!</div>
        </div>
        <div class="stat-card s-over">
          <div class="stat-label-sm">Overdue</div>
          <div class="stat-value" id="s-over">0</div>
