                <div class="product-info">
                    <div class="product-name">Running Shoes Comfort</div>
                    <div class="rating">
                        <span class="stars">★ 4.6</span>
                        <span class="rating-count">2145</span>
                    </div>
                    <div class="price-container">
                        <span class="price">₹1499</span>
                        <span class="original-price">₹2999</span>
                        <span class="discount">50% off</span>
                    </div>
                    <button class="add-to-cart-btn">Add to Cart</button>
                </div>
            </div>
            <div class="product-card" data-category="sports">
                <img src="https://images5.alphacoders.com/632/632664.jpg" alt="Sports Shoes" class="product-image">
                <div class="product-info">
                    <div class="product-name">Running Shoes Pro</div>
                    <div class="rating">
                        <span class="stars">★ 4.6</span>
                        <span class="rating-count">2145</span>
                    </div>
                    <div class="price-container">
                        <span class="price">₹1499</span>
                        <span class="original-price">₹2999</span>
                        <span class="discount">50% off</span>
