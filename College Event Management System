<script>
const API = 'http://localhost:8080/api';
let eventsData = [], studentsData = [], deptsData = [];

function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('nav a').forEach(a => a.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  const pages = ['dashboard','events','students','registrations','attendance','results','reports'];
  document.querySelectorAll('nav a')[pages.indexOf(name)].classList.add('active');
  const loaders = { dashboard: loadDashboard, events: loadEvents, students: loadStudents, registrations: loadRegistrations, attendance: loadAttendancePage, results: loadResultsPage, reports: loadReports };
  if (loaders[name]) loaders[name]();
}

function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = `toast show ${type}`;
  setTimeout(() => t.classList.remove('show'), 3500);
}

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.addEventListener('click', e => { if (e.target.classList.contains('modal-overlay')) e.target.classList.remove('open'); });

async function api(path, method = 'GET', body = null) {
  try {
    const opts = { method, headers: { 'Content-Type': 'application/json' } };
    if (body) opts.body = JSON.stringify(body);
    const r = await fetch(API + path, opts);
    if (!r.ok) { const err = await r.json().catch(() => ({ message: `HTTP ${r.status}` })); throw new Error(err.message || `HTTP ${r.status}`); }
    return await r.json();
  } catch (err) {
    if (method !== 'GET') showToast('❌ ' + err.message, 'error');
    return method === 'GET' ? [] : { success: false, message: err.message };
  }
}

function fillDeptSelects() {
  const opts = `<option value="">-- Select --</option>` + deptsData.map(d => `<option value="${d.id}">${d.name} (${d.code})</option>`).join('');
  ['ev-dept','st-dept'].forEach(id => { const el = document.getElementById(id); if(el) el.innerHTML = opts; });
}
function fillEventSelects(ids) {
  const opts = `<option value="">-- Select Event --</option>` + eventsData.map(e => `<option value="${e.id}">${e.title}</option>`).join('');
  ids.forEach(id => { const el = document.getElementById(id); if(el) el.innerHTML = opts; });
}
function fillStudentSelects(ids) {
  const opts = `<option value="">-- Select Student --</option>` + studentsData.map(s => `<option value="${s.id}">${s.roll_number} – ${s.name}</option>`).join('');
  ids.forEach(id => { const el = document.getElementById(id); if(el) el.innerHTML = opts; });
}

// DASHBOARD
async function loadDashboard() {
  const d = await api('/dashboard');
  if (!d || !d.stats) return;
  document.getElementById('stat-events').textContent   = d.stats.total_events;
  document.getElementById('stat-students').textContent = d.stats.total_students;
  document.getElementById('stat-regs').textContent     = d.stats.total_registrations;
  document.getElementById('stat-upcoming').textContent = d.stats.upcoming_events;
  document.getElementById('recent-events').innerHTML = (d.recent_events||[]).map(e => `
    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)">
      <div><div style="font-weight:600;font-size:0.9rem">${e.title}</div><div style="font-size:0.75rem;color:var(--text-muted)">${e.event_date} • ${e.venue}</div></div>
      <span class="badge badge-${e.status}">${e.status}</span>
    </div>`).join('') || '<div class="empty-state"><div class="empty-icon">📭</div><p>No events yet</p></div>';
  document.getElementById('top-events').innerHTML = (d.top_events||[]).map((e,i) => `
    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)">
      <div style="display:flex;align-items:center;gap:10px"><span style="font-weight:700;font-family:'Space Mono';color:var(--primary-light)">#${i+1}</span><span>${e.title}</span></div>
      <span style="font-weight:700;color:var(--secondary)">${e.cnt} 👥</span>
    </div>`).join('') || '<div class="empty-state"><div class="empty-icon">📊</div><p>No data yet</p></div>';
}

// EVENTS
async function loadEvents() {
  eventsData = await api('/events');
  deptsData  = await api('/departments');
  fillDeptSelects();
  renderEvents(eventsData);
}
function filterEvents() {
  const q = document.getElementById('event-search').value.toLowerCase();
  renderEvents(eventsData.filter(e => e.title.toLowerCase().includes(q) || e.category.toLowerCase().includes(q) || e.venue.toLowerCase().includes(q)));
}
function renderEvents(list) {
  const grid = document.getElementById('events-grid');
  if (!list.length) { grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">📭</div><p>No events found. Add your first event!</p></div>'; return; }
  grid.innerHTML = list.map(e => `
    <div class="event-card">
      <div class="event-card-header">
        <div class="event-card-title">${e.title}</div>
        <span class="badge badge-${(e.category||'').toLowerCase()}">${e.category}</span>
      </div>
      <div class="event-meta">📅 ${e.event_date} &nbsp; ⏰ ${e.event_time}</div>
      <div class="event-meta">📍 ${e.venue}</div>
      <div class="event-meta">🏛️ ${e.dept_name || 'All Departments'}</div>
      ${e.organizer_name ? `<div class="event-meta">👤 ${e.organizer_name}</div>` : ''}
      <div class="event-stats">
        <div class="event-stat">👥 Registered<br><strong>${e.registered_count||0}</strong></div>
        <div class="event-stat">🎯 Max<br><strong>${e.max_participants}</strong></div>
        <div class="event-stat">📌 Status<br><strong><span class="badge badge-${e.status}">${e.status}</span></strong></div>
      </div>
      <div class="event-actions">
        <button class="btn btn-edit btn-sm" onclick="openEditEvent(${e.id})">✏️ Edit</button>
        <button class="btn btn-danger btn-sm" onclick="deleteEvent(${e.id})">🗑️ Delete</button>
      </div>
    </div>`).join('');
}
function openAddEvent() {
  document.getElementById('event-modal-title').textContent = '🎪 Add New Event';
  document.getElementById('ev-save-btn').textContent = '💾 Save Event';
  document.getElementById('ev-id').value = '';
  ['ev-title','ev-venue','ev-desc','ev-org-name','ev-org-email','ev-date','ev-time','ev-deadline'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('ev-maxp').value = '100';
  document.getElementById('ev-category').value = 'Technical';
  document.getElementById('ev-status').value = 'upcoming';
  document.getElementById('ev-dept').value = '';
  openModal('event-modal');
}
function openEditEvent(id) {
  const e = eventsData.find(x => x.id === id); if (!e) return;
  document.getElementById('event-modal-title').textContent = '✏️ Edit Event';
  document.getElementById('ev-save-btn').textContent = '💾 Update Event';
  document.getElementById('ev-id').value        = e.id;
  document.getElementById('ev-title').value     = e.title || '';
  document.getElementById('ev-category').value  = e.category || 'Technical';
  document.getElementById('ev-venue').value     = e.venue || '';
  document.getElementById('ev-date').value      = e.event_date || '';
  document.getElementById('ev-time').value      = e.event_time || '';
  document.getElementById('ev-maxp').value      = e.max_participants || 100;
  document.getElementById('ev-deadline').value  = e.registration_deadline || '';
  document.getElementById('ev-dept').value      = e.department_id || '';
  document.getElementById('ev-org-name').value  = e.organizer_name || '';
  document.getElementById('ev-org-email').value = e.organizer_email || '';
  document.getElementById('ev-desc').value      = e.description || '';
  document.getElementById('ev-status').value    = e.status || 'upcoming';
  openModal('event-modal');
}
async function saveEvent() {
  const id    = document.getElementById('ev-id').value;
  const title = document.getElementById('ev-title').value.trim();
  const venue = document.getElementById('ev-venue').value.trim();
  const date  = document.getElementById('ev-date').value;
  const time  = document.getElementById('ev-time').value;
  if (!title) return showToast('❌ Event Title is required!', 'error');
  if (!venue) return showToast('❌ Venue is required!', 'error');
  if (!date)  return showToast('❌ Date is required!', 'error');
  if (!time)  return showToast('❌ Time is required!', 'error');
  const data = {
    title, venue, event_date: date, event_time: time,
    category: document.getElementById('ev-category').value,
    max_participants: parseInt(document.getElementById('ev-maxp').value)||100,
    registration_deadline: document.getElementById('ev-deadline').value,
    department_id: document.getElementById('ev-dept').value || null,
    organizer_name: document.getElementById('ev-org-name').value,
    organizer_email: document.getElementById('ev-org-email').value,
    description: document.getElementById('ev-desc').value,
    status: document.getElementById('ev-status').value,
  };
  if (id) { data.id = parseInt(id); }
  const r = await api(id ? '/events/update' : '/events', 'POST', data);
  if (r.success) { showToast(r.message); closeModal('event-modal'); loadEvents(); }
  else showToast(r.message || '❌ Failed!', 'error');
}
async function deleteEvent(id) {
  if (!confirm('⚠️ Delete this event and all registrations?')) return;
  const r = await api('/events/delete', 'POST', { id });
  if (r.success) { showToast(r.message); loadEvents(); }
  else showToast(r.message, 'error');
}

// STUDENTS
async function loadStudents() {
  studentsData = await api('/students');
  deptsData    = await api('/departments');
  fillDeptSelects();
  renderStudents(studentsData);
}
function filterStudents() {
  const q = document.getElementById('student-search').value.toLowerCase();
  renderStudents(studentsData.filter(s => s.name.toLowerCase().includes(q) || s.roll_number.toLowerCase().includes(q) || s.email.toLowerCase().includes(q)));
}
function renderStudents(list) {
  const tbody = document.getElementById('students-tbody');
  if (!list.length) { tbody.innerHTML = '<tr><td colspan="8"><div class="empty-state"><div class="empty-icon">👤</div><p>No students yet</p></div></td></tr>'; return; }
  tbody.innerHTML = list.map((s,i) => `
    <tr>
      <td style="color:var(--text-muted)">${i+1}</td>
      <td><strong>${s.name}</strong></td>
      <td style="font-family:'Space Mono';font-size:0.82rem;color:var(--primary-light)">${s.roll_number}</td>
      <td style="color:var(--text-muted);font-size:0.83rem">${s.email}</td>
      <td style="color:var(--text-muted);font-size:0.83rem">${s.phone||'—'}</td>
      <td>${s.dept_name||'—'}</td>
      <td style="text-align:center"><span style="background:rgba(139,92,246,0.15);color:#C4B5FD;padding:3px 10px;border-radius:20px;font-size:0.78rem;font-weight:600">Year ${s.year}</span></td>
      <td><div style="display:flex;gap:6px">
        <button class="btn btn-edit btn-sm" onclick="openEditStudent(${s.id})">✏️ Edit</button>
        <button class="btn btn-danger btn-sm" onclick="deleteStudent(${s.id})">🗑️</button>
      </div></td>
    </tr>`).join('');
}
function openAddStudent() {
  document.getElementById('student-modal-title').textContent = '👨‍🎓 Add New Student';
  document.getElementById('st-save-btn').textContent = '💾 Save Student';
  document.getElementById('st-id').value = '';
  ['st-name','st-roll','st-email','st-phone'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('st-year').value = '1';
  document.getElementById('st-dept').value = '';
  openModal('student-modal');
}
function openEditStudent(id) {
  const s = studentsData.find(x => x.id === id); if (!s) return;
  document.getElementById('student-modal-title').textContent = '✏️ Edit Student';
  document.getElementById('st-save-btn').textContent = '💾 Update Student';
  document.getElementById('st-id').value    = s.id;
  document.getElementById('st-name').value  = s.name||'';
  document.getElementById('st-roll').value  = s.roll_number||'';
  document.getElementById('st-email').value = s.email||'';
  document.getElementById('st-phone').value = s.phone||'';
  document.getElementById('st-year').value  = s.year||'1';
  document.getElementById('st-dept').value  = s.department_id||'';
  openModal('student-modal');
}
async function saveStudent() {
  const id    = document.getElementById('st-id').value;
  const name  = document.getElementById('st-name').value.trim();
  const roll  = document.getElementById('st-roll').value.trim();
  const email = document.getElementById('st-email').value.trim();
  if (!name)  return showToast('❌ Name is required!', 'error');
  if (!roll)  return showToast('❌ Roll Number is required!', 'error');
  if (!email) return showToast('❌ Email is required!', 'error');
  const data = { name, roll_number: roll, email, phone: document.getElementById('st-phone').value, department_id: document.getElementById('st-dept').value||null, year: document.getElementById('st-year').value };
  if (id) { data.id = parseInt(id); }
  const r = await api(id ? '/students/update' : '/students', 'POST', data);
  if (r.success) { showToast(r.message); closeModal('student-modal'); loadStudents(); }
  else showToast(r.message||'❌ Failed!', 'error');
}
async function deleteStudent(id) {
  if (!confirm('⚠️ Delete this student and their registrations?')) return;
  const r = await api('/students/delete', 'POST', { id });
  if (r.success) { showToast(r.message); loadStudents(); }
  else showToast(r.message, 'error');
}

// REGISTRATIONS
async function loadRegistrations() {
  const [regs, events, students, depts] = await Promise.all([api('/registrations'), api('/events'), api('/students'), api('/departments')]);
  eventsData = events; studentsData = students; deptsData = depts;
  fillEventSelects(['reg-event']); fillStudentSelects(['reg-student']);
  const tbody = document.getElementById('regs-tbody');
  if (!regs.length) { tbody.innerHTML = '<tr><td colspan="8"><div class="empty-state"><div class="empty-icon">📋</div><p>No registrations yet</p></div></td></tr>'; return; }
  tbody.innerHTML = regs.map((r,i) => `
    <tr>
      <td style="color:var(--text-muted)">${i+1}</td>
      <td><strong>${r.event_title}</strong></td>
      <td>${r.student_name}</td>
      <td style="font-family:'Space Mono';font-size:0.82rem;color:var(--primary-light)">${r.roll_number}</td>
      <td style="font-size:0.8rem;color:var(--text-muted)">${(r.registration_date||'').slice(0,10)}</td>
      <td><span class="badge badge-${r.payment_status}">${r.payment_status}</span></td>
      <td><span class="badge badge-${r.attendance}">${r.attendance}</span></td>
      <td><button class="btn btn-danger btn-sm" onclick="deleteRegistration(${r.id})">🗑️ Remove</button></td>
    </tr>`).join('');
}
async function saveRegistration() {
  const event_id = document.getElementById('reg-event').value;
  const student_id = document.getElementById('reg-student').value;
  if (!event_id || !student_id) return showToast('❌ Select both Event and Student!', 'error');
  const r = await api('/registrations', 'POST', { event_id: parseInt(event_id), student_id: parseInt(student_id), payment_status: document.getElementById('reg-payment').value });
  if (r.success) { showToast(r.message); closeModal('reg-modal'); loadRegistrations(); }
  else showToast(r.message, 'error');
}
async function deleteRegistration(id) {
  if (!confirm('Remove this registration?')) return;
  const r = await api('/registrations/delete', 'POST', { id });
  if (r.success) { showToast(r.message); loadRegistrations(); }
  else showToast(r.message, 'error');
}

// ATTENDANCE
async function loadAttendancePage() {
  eventsData = await api('/events');
  const sel = document.getElementById('att-event-select');
  sel.innerHTML = '<option value="">-- Choose an Event --</option>' + eventsData.map(e => `<option value="${e.id}">${e.title} (${e.event_date})</option>`).join('');
  document.getElementById('att-tbody').innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--text-muted);padding:30px">👆 Select an event above to mark attendance</td></tr>';
}
async function loadAttendance() {
  const event_id = document.getElementById('att-event-select').value; if (!event_id) return;
  const regs = await api(`/registrations?event_id=${event_id}`);
  const tbody = document.getElementById('att-tbody');
  if (!regs.length) { tbody.innerHTML = '<tr><td colspan="5"><div class="empty-state"><div class="empty-icon">👤</div><p>No registrations for this event</p></div></td></tr>'; return; }
  tbody.innerHTML = regs.map((r,i) => `
    <tr id="att-row-${r.id}">
      <td style="color:var(--text-muted)">${i+1}</td>
      <td><strong>${r.student_name}</strong></td>
      <td style="font-family:'Space Mono';font-size:0.82rem;color:var(--primary-light)">${r.roll_number}</td>
      <td><span class="badge badge-${r.attendance}" id="att-badge-${r.id}">${r.attendance}</span></td>
      <td>
        <button class="att-btn ${r.attendance==='present'?'absent':'present'}" id="att-btn-${r.id}" onclick="toggleAttendance(${r.id},'${r.attendance}')">
          ${r.attendance==='present'?'❌ Mark Absent':'✅ Mark Present'}
        </button>
      </td>
    </tr>`).join('');
}
async function toggleAttendance(id, current) {
  const next = current === 'present' ? 'absent' : 'present';
  const r = await api('/attendance', 'POST', { id, attendance: next });
  if (r.success) {
    document.getElementById(`att-badge-${id}`).className = `badge badge-${next}`;
    document.getElementById(`att-badge-${id}`).textContent = next;
    const btn = document.getElementById(`att-btn-${id}`);
    btn.className = `att-btn ${next==='present'?'absent':'present'}`;
    btn.textContent = next==='present'?'❌ Mark Absent':'✅ Mark Present';
    btn.onclick = () => toggleAttendance(id, next);
    showToast(r.message);
  } else showToast(r.message, 'error');
}

// RESULTS
async function loadResultsPage() {
  const [events, students] = await Promise.all([api('/events'), api('/students')]);
  eventsData = events; studentsData = students;
  fillEventSelects(['res-event','result-event-select']);
  fillStudentSelects(['res-student']);
  loadResults();
}
async function loadResults() {
  const event_id = document.getElementById('result-event-select').value;
  const results = await api('/results' + (event_id ? `?event_id=${event_id}` : ''));
  const container = document.getElementById('results-list');
  if (!results.length) { container.innerHTML = '<div class="empty-state"><div class="empty-icon">🏆</div><p>No results yet. Add winners!</p></div>'; return; }
  const grouped = {};
  results.forEach(r => { if (!grouped[r.event_title]) grouped[r.event_title]=[]; grouped[r.event_title].push(r); });
  container.innerHTML = Object.entries(grouped).map(([event,items]) => `
    <div class="card">
      <div class="card-title">🎪 ${event}</div>
      ${items.map(r => {
        const rc = r.position===1?'rank-1':r.position===2?'rank-2':r.position===3?'rank-3':'rank-other';
        const medal = r.position===1?'🥇':r.position===2?'🥈':r.position===3?'🥉':`#${r.position}`;
        return `<div class="leaderboard-item">
          <div class="rank-num ${rc}">${medal}</div>
          <div style="flex:1"><div style="font-weight:700">${r.student_name}</div><div style="font-size:0.78rem;color:var(--text-muted)">${r.roll_number}${r.prize?' • 🏅 '+r.prize:''}</div></div>
          ${r.score!=null?`<div style="font-family:'Space Mono';font-size:1.1rem;font-weight:700;color:var(--secondary)">${r.score}</div>`:''}
        </div>`;
      }).join('')}
    </div>`).join('');
}
async function saveResult() {
  const event_id = document.getElementById('res-event').value;
  const student_id = document.getElementById('res-student').value;
  if (!event_id || !student_id) return showToast('❌ Select Event and Student!', 'error');
  const r = await api('/results', 'POST', { event_id: parseInt(event_id), student_id: parseInt(student_id), position: parseInt(document.getElementById('res-pos').value)||null, score: parseFloat(document.getElementById('res-score').value)||null, prize: document.getElementById('res-prize').value, remarks: document.getElementById('res-remarks').value });
  if (r.success) { showToast(r.message); closeModal('result-modal'); loadResults(); }
  else showToast(r.message, 'error');
}

// REPORTS
async function loadReports() {
  const [events, students, regs, depts] = await Promise.all([api('/events'), api('/students'), api('/registrations'), api('/departments')]);
  const catCount = {};
  events.forEach(e => { catCount[e.category]=(catCount[e.category]||0)+1; });
  const maxCat = Math.max(...Object.values(catCount),1);
  document.getElementById('report-categories').innerHTML = Object.entries(catCount).map(([cat,cnt]) => `
    <div style="margin-bottom:14px">
      <div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="font-weight:600">${cat}</span><span style="color:var(--primary-light);font-family:'Space Mono'">${cnt}</span></div>
      <div class="prog-bar"><div class="prog-fill" style="width:${(cnt/maxCat*100).toFixed(0)}%"></div></div>
    </div>`).join('') || '<div class="empty-state"><div class="empty-icon">📊</div><p>No data</p></div>';
  const deptCount = {};
  students.forEach(s => { const d=depts.find(x=>x.id===s.department_id); const name=d?d.name:'Unknown'; deptCount[name]=(deptCount[name]||0)+1; });
  const maxDept = Math.max(...Object.values(deptCount),1);
  document.getElementById('report-departments').innerHTML = Object.entries(deptCount).map(([dept,cnt]) => `
    <div style="margin-bottom:14px">
      <div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="font-weight:600">${dept}</span><span style="color:var(--success);font-family:'Space Mono'">${cnt}</span></div>
      <div class="prog-bar"><div class="prog-fill" style="width:${(cnt/maxDept*100).toFixed(0)}%;background:linear-gradient(90deg,var(--success),var(--info))"></div></div>
    </div>`).join('') || '<div class="empty-state"><div class="empty-icon">🏛️</div><p>No data</p></div>';
  const paid=regs.filter(r=>r.payment_status==='paid').length;
  const pending=regs.filter(r=>r.payment_status==='pending').length;
  const present=regs.filter(r=>r.attendance==='present').length;
  document.getElementById('report-summary').innerHTML = `
    <table>
      <thead><tr><th>📊 Metric</th><th>📈 Value</th></tr></thead>
      <tbody>
        <tr><td>Total Events</td><td><strong style="color:var(--primary-light)">${events.length}</strong></td></tr>
        <tr><td>Upcoming Events</td><td><strong style="color:var(--accent)">${events.filter(e=>e.status==='upcoming').length}</strong></td></tr>
        <tr><td>Completed Events</td><td><strong style="color:var(--success)">${events.filter(e=>e.status==='completed').length}</strong></td></tr>
        <tr><td>Total Students</td><td><strong style="color:var(--secondary)">${students.length}</strong></td></tr>
        <tr><td>Total Registrations</td><td><strong style="color:var(--info)">${regs.length}</strong></td></tr>
        <tr><td>Payments Paid</td><td><strong style="color:var(--success)">${paid}</strong></td></tr>
        <tr><td>Payments Pending</td><td><strong style="color:var(--secondary)">${pending}</strong></td></tr>
        <tr><td>Present in Attendance</td><td><strong style="color:var(--success)">${present}</strong></td></tr>
      </tbody>
    </table>`;
}

loadDashboard();
